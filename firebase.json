{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "site": "henriquebonfim",
    "headers": [
      {
        "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css|js|css|webp|png|jpg|jpeg)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
